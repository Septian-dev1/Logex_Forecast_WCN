# === WCN Forecast Environment Configuration ===
# Copy file ini menjadi .env dan sesuaikan nilainya

# Tahun target untuk forecast dan pivot table
TARGET_TAHUN=2025

# Jumlah bulan untuk backtesting evaluation
TEST_MONTHS=6

# Jumlah CPU cores untuk parallel processing (-1 = semua core)
N_JOBS=-1

# Path input data
DATA_INPUT_PATH=data/raw/Data 1-2.csv

# Path output
OUTPUT_CSV_PATH=data/output/prophet_forecast.csv
OUTPUT_EXCEL_PATH=data/output/prophet_pivot_table.xlsx
